includes:
    - vendor/larastan/larastan/extension.neon

parameters:

    paths:
        - app/
        - config/
        - routes/

    # Level 5 is the quality gate for Sprint 1.
    # Rationale for excluded paths:
    #
    # - database/migrations/ : DDL scripts that use fluent Schema Builder methods
    #   (e.g. ->comment() chained on ForeignKeyDefinition) that Larastan does not
    #   model. Migrations are not domain logic — they are verified by running them,
    #   not by static analysis.
    #
    # - tests/ : Pest's functional DSL (test(), it(), beforeEach()) binds $this to
    #   a Laravel TestCase at runtime. PHPStan cannot resolve this binding without
    #   the dedicated pest-phpstan extension. Tests are validated by `php artisan test`.
    #
    level: 5

    excludePaths:
        - ./routes/console.php
