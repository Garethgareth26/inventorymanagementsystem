APP_NAME="CV Akuna Inventory"
APP_ENV=production
APP_KEY=                   # Required — generate with: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-cloudrun-url.run.app
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database — Supabase PostgreSQL ──────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=                   # Supabase host (db.xxxx.supabase.co)
DB_PORT=5432
DB_DATABASE=postgres        # Supabase default DB name
DB_USERNAME=postgres
DB_PASSWORD=                # Supabase DB password

# ── Session / Cache / Queue — Upstash Redis ─────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=                 # Upstash Redis host (xxxxx.upstash.io)
REDIS_PORT=6379
REDIS_PASSWORD=             # Upstash Redis password

# ── Filesystem — Supabase Storage ────────────────────────────────────────────
FILESYSTEM_DISK=supabase    # Custom disk driver configured in config/filesystems.php
SUPABASE_STORAGE_URL=       # https://xxxx.supabase.co/storage/v1
SUPABASE_STORAGE_KEY=       # Supabase anon/service key
SUPABASE_STORAGE_BUCKET=reports

# ── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@cvakuna.id"
MAIL_FROM_NAME="${APP_NAME}"

# ── Misc ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
BROADCAST_CONNECTION=log
